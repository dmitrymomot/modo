server:
  port: ${PORT:-8080}
  secret_key: ${SECRET_KEY}
  static_files:
    prefix: /static
templates:
  path: templates/app
database:
  url: ${DATABASE_URL}
  max_connections: 20
  min_connections: 5
email:
  templates_path: templates/emails
  default_from_name: ${EMAIL_FROM_NAME}
  default_from_email: ${EMAIL_FROM_ADDRESS}
  smtp:
    host: ${SMTP_HOST}
    port: ${SMTP_PORT:-587}
    username: ${SMTP_USERNAME}
    password: ${SMTP_PASSWORD}
i18n:
  path: locales
  default_locale: en
upload:
  backend: s3
  s3:
    bucket: ${S3_BUCKET}
    region: ${S3_REGION}
    endpoint: ${S3_ENDPOINT}
    access_key_id: ${S3_ACCESS_KEY_ID}
    secret_access_key: ${S3_SECRET_ACCESS_KEY}
